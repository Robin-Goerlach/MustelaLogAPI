<Window x:Class="MustelaLog.Client.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:MustelaLog.Client.Wpf.Converters"
        mc:Ignorable="d"
        Title="Mustela Log Client"
        Height="900"
        Width="1500"
        MinHeight="700"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!--
            Register the converter locally in the window to make sure the DataGrid cell style
            can always resolve it, even if application-wide resources are not loaded as expected.
        -->
        <conv:SeverityBrushConverter x:Key="SeverityBrushConverter" />

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SectionHeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="FilterLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FilterControlStyle" TargetType="Control">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="MainDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="True" />
            <Setter Property="CanUserResizeColumns" Value="True" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AlternatingRowBackground" Value="#FFF8F8F8" />
            <Setter Property="HorizontalGridLinesBrush" Value="#FFE5E5E5" />
            <Setter Property="VerticalGridLinesBrush" Value="#FFE5E5E5" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="6,4,6,4" />
            <Setter Property="Foreground" Value="{Binding Severity, Converter={StaticResource SeverityBrushConverter}}" />
        </Style>

        <Style x:Key="ReadOnlyTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="6,4,6,4" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Top toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#FFF3F3F3"
                BorderBrush="#FFDADADA"
                BorderThickness="0,0,0,1"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Refresh"
                            Width="90"
                            Margin="0,0,8,0"
                            Command="{Binding RefreshCommand}" />

                    <Button Content="Send Test Log"
                            Width="120"
                            Margin="0,0,8,0"
                            Command="{Binding SendTestLogCommand}" />

                    <Button Content="Export CSV"
                            Width="100"
                            Margin="0,0,8,0"
                            Command="{Binding ExportCsvCommand}" />

                    <Button Content="Export JSON"
                            Width="100"
                            Margin="0,0,8,0"
                            Command="{Binding ExportJsonCommand}" />

                    <Button Content="Related Events"
                            Width="120"
                            Margin="0,0,8,0"
                            Command="{Binding LoadRelatedEventsCommand}" />

                    <Button Content="Diagnostics"
                            Width="100"
                            Command="{Binding ShowDiagnosticsCommand}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Time Mode:"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <ComboBox Width="110"
                              SelectedItem="{Binding SelectedTimeDisplayMode}">
                        <ComboBoxItem Content="Local" />
                        <ComboBoxItem Content="Utc" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding ConnectionStatus}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding LastRefreshText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ResponseTimeText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding ActiveTimeModeText}" />
            </StatusBarItem>
        </StatusBar>

        <!-- Main content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!-- Filter panel -->
            <Border Grid.Column="0"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="0,0,1,0"
                    Padding="12"
                    Background="#FFFAFAFA">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Filters" Style="{StaticResource SectionHeaderTextBlockStyle}" />

                        <TextBlock Text="Quick time range" Style="{StaticResource FilterLabelStyle}" />
                        <ComboBox SelectedItem="{Binding SelectedQuickRange}" Margin="0,0,0,10">
                            <ComboBoxItem Content="Last 5 minutes" />
                            <ComboBoxItem Content="Last 15 minutes" />
                            <ComboBoxItem Content="Last hour" />
                            <ComboBoxItem Content="Today" />
                            <ComboBoxItem Content="Last 24 hours" />
                            <ComboBoxItem Content="Last 7 days" />
                            <ComboBoxItem Content="Custom" />
                        </ComboBox>

                        <TextBlock Text="From" Style="{StaticResource FilterLabelStyle}" />
                        <DatePicker SelectedDate="{Binding FilterFromDate}" Margin="0,0,0,10" />

                        <TextBlock Text="To" Style="{StaticResource FilterLabelStyle}" />
                        <DatePicker SelectedDate="{Binding FilterToDate}" Margin="0,0,0,10" />

                        <TextBlock Text="Source" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterSource}" Margin="0,0,0,10" />

                        <TextBlock Text="Host" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterHost}" Margin="0,0,0,10" />

                        <TextBlock Text="Service" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterService}" Margin="0,0,0,10" />

                        <TextBlock Text="Severity" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterSeverity}" Margin="0,0,0,10" />

                        <TextBlock Text="Category" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterCategory}" Margin="0,0,0,10" />

                        <TextBlock Text="Action" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterAction}" Margin="0,0,0,10" />

                        <TextBlock Text="Outcome" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterOutcome}" Margin="0,0,0,10" />

                        <TextBlock Text="Correlation ID" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterCorrelationId}" Margin="0,0,0,10" />

                        <TextBlock Text="Trace ID" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterTraceId}" Margin="0,0,0,10" />

                        <TextBlock Text="Request ID" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterRequestId}" Margin="0,0,0,10" />

                        <TextBlock Text="Full-text search" Style="{StaticResource FilterLabelStyle}" />
                        <TextBox Text="{Binding FilterSearchText}" Margin="0,0,0,10" />

                        <CheckBox Content="Only events with payload"
                                  IsChecked="{Binding FilterOnlyWithPayload}"
                                  Margin="0,0,0,8" />

                        <CheckBox Content="Only events with correlation ID"
                                  IsChecked="{Binding FilterOnlyWithCorrelationId}"
                                  Margin="0,0,0,8" />

                        <CheckBox Content="Only events with actor"
                                  IsChecked="{Binding FilterOnlyWithActor}"
                                  Margin="0,0,0,12" />

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Apply"
                                    Width="90"
                                    Margin="0,0,8,0"
                                    Command="{Binding ApplyFiltersCommand}" />
                            <Button Content="Clear"
                                    Width="90"
                                    Command="{Binding ClearFiltersCommand}" />
                        </StackPanel>

                        <Separator Margin="0,16,0,16" />

                        <TextBlock Text="Saved Views" Style="{StaticResource SectionHeaderTextBlockStyle}" />

                        <ListBox ItemsSource="{Binding SavedViews}"
                                 SelectedItem="{Binding SelectedSavedView}"
                                 DisplayMemberPath="Name"
                                 Height="150"
                                 Margin="0,0,0,10" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Save Current"
                                    Width="100"
                                    Margin="0,0,8,0"
                                    Command="{Binding SaveCurrentViewCommand}" />
                            <Button Content="Load"
                                    Width="70"
                                    Margin="0,0,8,0"
                                    Command="{Binding LoadSavedViewCommand}" />
                            <Button Content="Delete"
                                    Width="70"
                                    Command="{Binding DeleteSavedViewCommand}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Center content -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <!-- Log table -->
                <DataGrid Grid.Row="0"
                          Style="{StaticResource MainDataGridStyle}"
                          ItemsSource="{Binding LogEvents}"
                          SelectedItem="{Binding SelectedLogEvent, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Occurred At" Binding="{Binding OccurredAtDisplay}" Width="160" />
                        <DataGridTextColumn Header="Ingested At" Binding="{Binding IngestedAtDisplay}" Width="160" />
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                        <DataGridTextColumn Header="Source" Binding="{Binding SourceName}" Width="140" />
                        <DataGridTextColumn Header="Host" Binding="{Binding HostName}" Width="140" />
                        <DataGridTextColumn Header="Service" Binding="{Binding ServiceName}" Width="140" />
                        <DataGridTextColumn Header="Category" Binding="{Binding EventCategory}" Width="130" />
                        <DataGridTextColumn Header="Action" Binding="{Binding EventAction}" Width="120" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding EventOutcome}" Width="100" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                        <DataGridTextColumn Header="Correlation" Binding="{Binding CorrelationIdShort}" Width="140" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Aggregation / chart placeholder -->
                <Border Grid.Row="1"
                        BorderBrush="#FFE0E0E0"
                        BorderThickness="0,1,0,0"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Aggregations"
                                   Style="{StaticResource SectionHeaderTextBlockStyle}" />

                        <TabControl Grid.Row="1">
                            <TabItem Header="Severity">
                                <DataGrid ItemsSource="{Binding SeverityAggregationRows}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Key}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <TabItem Header="Sources">
                                <DataGrid ItemsSource="{Binding SourceAggregationRows}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Source" Binding="{Binding Key}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>

                            <TabItem Header="Time">
                                <DataGrid ItemsSource="{Binding TimeAggregationRows}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time Bucket" Binding="{Binding Key}" Width="*" />
                                        <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="120" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Detail panel -->
            <Border Grid.Column="2"
                    BorderBrush="#FFE0E0E0"
                    BorderThickness="1,0,0,0"
                    Padding="12"
                    Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Details" Style="{StaticResource SectionHeaderTextBlockStyle}" />

                        <Expander Header="General" IsExpanded="True">
                            <StackPanel Margin="8">
                                <TextBlock Text="Event ID" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.EventId}" />

                                <TextBlock Text="Occurred At" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.OccurredAtDisplay}" />

                                <TextBlock Text="Observed At" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.ObservedAtDisplay}" />

                                <TextBlock Text="Received At" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.ReceivedAtDisplay}" />

                                <TextBlock Text="Ingested At" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.IngestedAtDisplay}" />

                                <TextBlock Text="Severity" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.Severity}" />

                                <TextBlock Text="Event Name" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.EventName}" />

                                <TextBlock Text="Category" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.EventCategory}" />

                                <TextBlock Text="Action" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.EventAction}" />

                                <TextBlock Text="Outcome" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.EventOutcome}" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Source" IsExpanded="False">
                            <StackPanel Margin="8">
                                <TextBlock Text="Source Name" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.SourceName}" />

                                <TextBlock Text="Source Key" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.SourceKey}" />

                                <TextBlock Text="Host" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.HostName}" />

                                <TextBlock Text="Service" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.ServiceName}" />

                                <TextBlock Text="Component" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.ComponentName}" />

                                <TextBlock Text="Environment" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.Environment}" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Correlation" IsExpanded="False">
                            <StackPanel Margin="8">
                                <TextBlock Text="Trace ID" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.TraceId}" />

                                <TextBlock Text="Span ID" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.SpanId}" />

                                <TextBlock Text="Correlation ID" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.CorrelationId}" />

                                <TextBlock Text="Request ID" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.RequestId}" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Message / Payload" IsExpanded="True">
                            <StackPanel Margin="8">
                                <TextBlock Text="Message" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}"
                                         MinHeight="80"
                                         Text="{Binding SelectedLogEvent.Message}" />

                                <TextBlock Text="Attributes JSON" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}"
                                         MinHeight="140"
                                         Text="{Binding SelectedLogEvent.AttributesJsonFormatted}" />

                                <TextBlock Text="Raw Payload JSON" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}"
                                         MinHeight="140"
                                         Text="{Binding SelectedLogEvent.RawPayloadJsonFormatted}" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Governance / Integrity" IsExpanded="False">
                            <StackPanel Margin="8">
                                <TextBlock Text="Classification" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.Classification}" />

                                <TextBlock Text="Retention Policy" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.RetentionPolicy}" />

                                <TextBlock Text="Legal Hold" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.LegalHold}" />

                                <TextBlock Text="Canonical Hash" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.CanonicalHash}" />

                                <TextBlock Text="Previous Hash" Style="{StaticResource FilterLabelStyle}" />
                                <TextBox Style="{StaticResource ReadOnlyTextBoxStyle}" Text="{Binding SelectedLogEvent.PreviousHash}" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>