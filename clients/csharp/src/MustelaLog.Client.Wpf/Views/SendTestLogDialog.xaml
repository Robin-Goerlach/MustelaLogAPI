<Window x:Class="MustelaLog.Client.Wpf.Views.SendTestLogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Send Test Log Event"
        Width="760"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Send" Width="120" Margin="0,0,8,0" Click="Send_Click" />
            <Button Content="Close" Width="120" Click="Close_Click" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="160" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Severity text:" VerticalAlignment="Center" /><TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SeverityText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="1" Text="Severity number:" VerticalAlignment="Center" /><TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SeverityNumber, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="2" Text="Message:" VerticalAlignment="Center" /><TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="3" Text="Event name:" VerticalAlignment="Center" /><TextBox Grid.Row="3" Grid.Column="1" Text="{Binding EventName, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="4" Text="Category:" VerticalAlignment="Center" /><TextBox Grid.Row="4" Grid.Column="1" Text="{Binding EventCategory, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="5" Text="Action:" VerticalAlignment="Center" /><TextBox Grid.Row="5" Grid.Column="1" Text="{Binding EventAction, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="6" Text="Outcome:" VerticalAlignment="Center" /><TextBox Grid.Row="6" Grid.Column="1" Text="{Binding EventOutcome, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="7" Text="Service:" VerticalAlignment="Center" /><TextBox Grid.Row="7" Grid.Column="1" Text="{Binding ServiceName, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="8" Text="Correlation ID:" VerticalAlignment="Center" /><TextBox Grid.Row="8" Grid.Column="1" Text="{Binding CorrelationId, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="9" Text="Trace ID:" VerticalAlignment="Center" /><TextBox Grid.Row="9" Grid.Column="1" Text="{Binding TraceId, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="10" Text="Request ID:" VerticalAlignment="Center" /><TextBox Grid.Row="10" Grid.Column="1" Text="{Binding RequestId, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Row="11" Text="Attributes JSON:" VerticalAlignment="Top" /><TextBox Grid.Row="11" Grid.Column="1" Text="{Binding AttributesJson, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" Height="250" />
                <TextBlock Grid.Row="12" Grid.ColumnSpan="2" Margin="0,10,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
