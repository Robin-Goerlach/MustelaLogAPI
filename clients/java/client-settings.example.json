{
  "api": {
    "baseUrl": "https://example.com/index.php",
    "routeParameterName": "route",
    "apiVersionPath": "/api/v1",
    "readBearerToken": "reader-token-here",
    "ingestBearerToken": "source-token-here",
    "timeoutSeconds": 20,
    "defaultPageSize": 50,
    "healthOnStartup": true
  },
  "diagnostics": {
    "logFilePath": "logs/mustralla-java-client.log",
    "maxEntriesInMemory": 1000
  },
  "export": {
    "defaultDirectory": "exports"
  },
  "ui": {
    "lookAndFeelSystem": true,
    "windowWidth": 1440,
    "windowHeight": 900,
    "autoLoadSourcesOnStartup": true,
    "autoLoadEventsOnStartup": true
  }
}
