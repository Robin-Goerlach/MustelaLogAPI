APP_NAME="SASD Logging Middleware"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC

APP_BASE_URL=https://example.com/index.php
APP_ROUTE_PARAM=route
APP_MAX_JSON_BYTES=262144
APP_ALLOWED_CLOCK_SKEW_SECONDS=300

DB_HOST=localhost
DB_PORT=3306
DB_NAME=loggingdb
DB_CHARSET=utf8mb4

# Falls IONOS oder der Tarif nur einen DB-Benutzer zulässt, können dieselben
# Zugangsdaten für Lesen und Schreiben verwendet werden. Die Anwendung trennt
# die Pfade trotzdem logisch.
DB_READ_USER=app_reader
DB_READ_PASS=change-me
DB_WRITE_USER=app_writer
DB_WRITE_PASS=change-me

# Lokales Technik-Log der Middleware (kein Ersatz für Audit-Logging!)
APP_LOCAL_LOG_FILE=var/log/app.log

# Optional: feste Origin-Liste für Browser-basierte Clients.
CORS_ALLOWED_ORIGINS=https://example.com

# Optional: ein zusätzliches Pepper für Token-Hashing in der Middleware.
# Nur setzen, wenn ein stabiler Wert sicher verwaltet werden kann.
AUTH_TOKEN_PEPPER=

RATE_LIMIT_ENABLED=true
RATE_LIMIT_INGEST_PER_MINUTE=120
RATE_LIMIT_READ_PER_MINUTE=300
